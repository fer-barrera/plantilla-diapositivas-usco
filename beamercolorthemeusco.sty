% Palette
\setbeamercolor*{palette primary}{fg=darkred!60!black,bg=uscogray}
\setbeamercolor*{palette secondary}{fg=darkred!70!black,bg=gray!15!white}
\setbeamercolor*{palette tertiary}{fg=gray!10!white,bg=uscodarkred}
\setbeamercolor*{palette quaternary}{fg=darkred,bg=gray!45!white}

% Set color theme
\setbeamercolor*{title page header}{fg=black}
\setbeamercolor*{frametitle}{bg=gray!15!white, fg=darkred}
\setbeamercolor*{framesubtitle}{bg=gray!15!white, fg=gray!60!black}
\setbeamercolor*{headline}{fg=red}
\setbeamercolor*{author}{fg=white}
\setbeamercolor*{summary}{fg=white}
\setbeamercolor*{date}{fg=white}
\setbeamercolor*{title}{fg=red}
\setbeamercolor*{institute}{fg=white}

% Box
\setbeamercolor{section box}{bg=uscoRed3, fg=white}

% bullet color
\setbeamercolor*{item}{fg=red}

% separation style
\setbeamercolor*{separation line}{}
\setbeamercolor*{fine separation line}{}

% Trasparency in itemizing
\setbeamercovered{transparent} 

\mode<all>